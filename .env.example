NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Legacy JWT anon key (eyJ...) or newer publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only JWT from Project Settings → API → service_role (eyJ...). Never the DB password.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring Price ID for Patron Circle (Dashboard → Products → monthly price)
STRIPE_MONTHLY_PRICE_ID=price_...

# Minutes before unpaid reserved tickets return to available
RESERVATION_EXPIRY_MINUTES=15

# Cron secret for /api/cron/release-reservations
CRON_SECRET=generate-a-long-random-string

NEXT_PUBLIC_SITE_URL=http://localhost:3000
